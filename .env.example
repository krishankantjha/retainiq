# ==============================================================================
# RetainIQ Production Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and modify credentials accordingly before deployment.
# WARNING: Do not commit the actual '.env' file containing real secrets to VCS!

# --- Database Orchestration Settings ---
# Database service user credentials
POSTGRES_USER=retainiq
# Cryptographically secure random password (change in production!)
POSTGRES_PASSWORD=retainiq_secure_pass_change_me_in_prod
# Name of the target schema
POSTGRES_DB=customer_retention
# Exposed host port for the Postgres instance
POSTGRES_PORT=5432

# --- FastAPI Backend Settings ---
# Core environment target mode (development, production)
APP_ENV=production
# Toggles detailed tracebacks and debug logging outputs (True, False)
DEBUG=False
# Signing secret for JWT authorization tokens. MUST be overridden in production!
# You can generate a random string using: openssl rand -hex 32
JWT_SECRET=super-secret-key-change-in-production-1234567890_override_me
# Allowed origins for CORS (comma-separated list)
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,https://retainiq.com
# Exposed host port for the backend container
BACKEND_PORT=8000

# --- Streamlit Frontend Settings ---
# Host port for the Streamlit dashboard container
FRONTEND_PORT=8501

# --- Nginx Reverse Proxy Settings ---
# Main entry port for public requests
NGINX_PORT=80
